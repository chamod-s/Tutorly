<Window x:Class="TutorlyDesktop.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TutorlyDesktop"
        mc:Ignorable="d"
        Title="Tutorly - Dashboard" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#0F172A">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Margin="0,10,0,25">
                    <TextBlock Text="TUTORLY" FontSize="22" FontWeight="Black" Foreground="#3B82F6"/>
                    <TextBlock Text="Desktop Dashboard" FontSize="11" Foreground="#64748B"/>
                </StackPanel>

                <!-- User Profile Summary -->
                <StackPanel Grid.Row="1" Margin="0,0,0,30">
                    <Border Width="60" Height="60" CornerRadius="30" Background="#1E293B" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBlock Name="UserInitials" Text="U" FontSize="20" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Name="UserNameText" Text="User Name" FontSize="15" FontWeight="Bold" Foreground="White"/>
                    <Border Background="#2563EB" CornerRadius="4" HorizontalAlignment="Left" Padding="6,2,6,2" Margin="0,4,0,0">
                        <TextBlock Name="UserRoleText" Text="ROLE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- Navigation Menu Items -->
                <StackPanel Grid.Row="2">
                    <Button Content="🏠  My Dashboard" Background="Transparent" Foreground="White" BorderThickness="0" 
                            HorizontalContentAlignment="Left" Padding="12,8,12,8" FontSize="13" Cursor="Hand" Margin="0,0,0,8"/>
                    <Button Content="📚  Browse Courses" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" 
                            HorizontalContentAlignment="Left" Padding="12,8,12,8" FontSize="13" Cursor="Hand" Margin="0,0,0,8"/>
                    <Button Content="👤  My Profile" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" 
                            HorizontalContentAlignment="Left" Padding="12,8,12,8" FontSize="13" Cursor="Hand" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Logout Button -->
                <Button Grid.Row="3" Content="🚪  Log Out" Background="#1E293B" Foreground="#EF4444" BorderThickness="0" 
                        Padding="12,10,12,10" FontSize="13" FontWeight="Bold" Cursor="Hand" Click="LogoutButton_Click">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Main Header -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Name="WelcomeHeadingText" Text="Welcome back, User!" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Name="SubheadingText" Text="Here is what's happening with your learning profile today." FontSize="13" Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Info Stats Cards -->
            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1 -->
                <Border Grid.Column="0" CornerRadius="12" Background="White" Padding="20" Margin="0,0,15,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#0F172A" Direction="320" ShadowDepth="2" Opacity="0.04" BlurRadius="10"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Name="Stat1Title" Text="Enrolled Courses" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Name="Stat1Val" Text="0" FontSize="28" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Grid.Column="1" CornerRadius="12" Background="White" Padding="20" Margin="0,0,15,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#0F172A" Direction="320" ShadowDepth="2" Opacity="0.04" BlurRadius="10"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Name="Stat2Title" Text="Hours Studied" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Name="Stat2Val" Text="12.5 hrs" FontSize="28" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border Grid.Column="2" CornerRadius="12" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#0F172A" Direction="320" ShadowDepth="2" Opacity="0.04" BlurRadius="10"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Name="Stat3Title" Text="Completed Lessons" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock Name="Stat3Val" Text="8 / 15" FontSize="28" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Dynamic Data Grid (Courses list) -->
            <Border Grid.Row="2" CornerRadius="12" Background="White" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Direction="320" ShadowDepth="2" Opacity="0.04" BlurRadius="10"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="GridTitleText" Text="Your Courses" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,15"/>

                    <DataGrid Name="CoursesDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="Transparent" BorderThickness="0" RowBackground="White" AlternatingRowBackground="#F8FAFC"
                              HeadersVisibility="Column" GridLinesVisibility="None" FontSize="13" Foreground="#334155">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8,10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Height" Value="38"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Course Title" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1*" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="1*" />
                            <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="1*" />
                            <DataGridTextColumn Header="Price (LKR)" Binding="{Binding Price}" Width="1*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
