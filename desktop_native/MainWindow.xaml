<Window x:Class="TutorlyDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TutorlyDesktop"
        mc:Ignorable="d"
        Title="Tutorly - Native Desktop App" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9"
        ResizeMode="CanMinimize">

    <Grid>
        <!-- Background Splashes -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E2E8F0" Offset="0.0"/>
                <GradientStop Color="#F1F5F9" Offset="0.5"/>
                <GradientStop Color="#E2E8F0" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border CornerRadius="16" Background="White" Width="420" Height="480"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Direction="320" ShadowDepth="4" Opacity="0.08" BlurRadius="20"/>
            </Border.Effect>
            
            <StackPanel Margin="35,40,35,40">
                <!-- App Logo/Header -->
                <TextBlock Text="TUTORLY" FontSize="26" FontWeight="Black" Foreground="#2563EB" 
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Professional Tutoring Platform" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Header Title -->
                <TextBlock Text="Welcome back" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,5"/>
                <TextBlock Text="Log in to manage your tutoring dashboard" FontSize="13" Foreground="#64748B" Margin="0,0,0,25"/>

                <!-- Error Message Area -->
                <Border Name="ErrorBorder" CornerRadius="8" Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1"
                        Padding="12,8,12,8" Margin="0,0,0,15" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Foreground="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Name="ErrorText" Text="Invalid email or password" Foreground="#991B1B" FontSize="12" 
                                   TextWrapping="Wrap" Width="300" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Email Input -->
                <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                <TextBox Name="EmailInput" Height="38" Padding="10,0,10,0" FontSize="13" VerticalContentAlignment="Center"
                         Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1.5" Margin="0,0,0,18"
                         GotFocus="Input_GotFocus" LostFocus="Input_LostFocus">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Password Input -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                <PasswordBox Name="PasswordInput" Height="38" Padding="10,0,10,0" FontSize="13" VerticalContentAlignment="Center"
                             Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1.5" Margin="0,0,0,25"
                             GotFocus="Input_GotFocus" LostFocus="Input_LostFocus">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Sign In Button -->
                <Button Name="SignInButton" Content="Sign In" Height="42" FontSize="14" FontWeight="Bold" Cursor="Hand"
                        Background="#2563EB" Foreground="White" BorderThickness="0" Click="SignInButton_Click">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2563EB"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Database Test Status -->
                <TextBlock Name="DbStatusText" Text="Connecting to database..." FontSize="11" Foreground="#94A3B8" 
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
