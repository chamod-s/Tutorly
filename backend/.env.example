# ─────────────────────────────────────────────
#  TUTORLY BACKEND — Environment Variables
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000
APP_NAME=TUTORLY
CLIENT_URL=http://localhost:3000

# PostgreSQL — Prisma connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tutorly?schema=public"

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# PayHere (Sri Lanka)
PAYHERE_MERCHANT_ID=your_payhere_merchant_id
PAYHERE_MERCHANT_SECRET=your_payhere_merchant_secret
PAYHERE_MODE=sandbox
PAYHERE_SANDBOX_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_LIVE_URL=https://www.payhere.lk/pay/checkout
PAYHERE_NOTIFY_URL=https://your-api-domain.com/api/v1/payments/webhook

# Storage (Cloudflare R2 / AWS S3)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=tutorly-media

# HLS / Media Server
HLS_BASE_URL=https://stream.your-domain.com
RTMP_INGEST_URL=rtmp://stream.your-domain.com/live

# Email (optional — for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="TUTORLY <noreply@tutorly.lk>"

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
